# Required for Prisma + API routes
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB?schema=public"

# Required for Prisma schema (pooled/direct connection for migrations/introspection)
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DB?schema=public"

# Required for JWT signing/verification in src/lib/auth
AUTH_SECRET="replace-with-a-long-random-secret"

# Optional: enables AI features (event parsing, maintenance diagnosis, device intelligence, etc.)
GEMINI_API_KEY=""
