// ═══════════════════════════════════════════════════════════════════════
// ATHLETICS MODULE
// ═══════════════════════════════════════════════════════════════════════

model Sport {
  id             String   @id @default(cuid())
  organizationId String
  name           String   // "Football", "Basketball", "Track & Field"
  abbreviation   String?  // "FB", "BKB", "TF"
  color          String   @default("#6b7280")
  icon           String?  // Lucide icon name
  seasonType     SportSeasonType @default(FALL)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  athleticSeasons AthleticSeason[]
  athleticTeams   AthleticTeam[]
  tournaments     Tournament[]
  statConfigs     SportStatConfig[]

  @@unique([organizationId, name])
  @@index([organizationId, isActive])
}

model AthleticSeason {
  id             String   @id @default(cuid())
  organizationId String
  sportId        String
  name           String   // "Fall 2026 Football"
  startDate      DateTime
  endDate        DateTime
  isCurrent      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  sport        Sport          @relation(fields: [sportId], references: [id], onDelete: Cascade)
  teams        AthleticTeam[]

  @@index([organizationId])
  @@index([sportId])
  @@index([organizationId, isCurrent])
}

model AthleticTeam {
  id             String   @id @default(cuid())
  organizationId String
  sportId        String
  seasonId       String
  name           String   // "Varsity Football", "JV Basketball"
  level          TeamLevel @default(VARSITY)
  gradeLevel     SchoolType?  // ELEMENTARY, MIDDLE_SCHOOL, HIGH_SCHOOL — null means org-wide / unspecified
  coachUserId    String?
  coachName      String?   // Free-form coach name (alternative to coachUserId)
  schoolId       String?
  calendarId     String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  sport        Sport           @relation(fields: [sportId], references: [id], onDelete: Cascade)
  season       AthleticSeason  @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  games        Game[]
  practices    Practice[]
  homeBrackets TournamentBracket[] @relation("BracketTeam1")
  awayBrackets TournamentBracket[] @relation("BracketTeam2")
  winBrackets  TournamentBracket[] @relation("BracketWinner")
  roster       AthleticRoster[]

  @@index([organizationId])
  @@index([sportId])
  @@index([seasonId])
  @@index([coachUserId])
}

model Game {
  id               String   @id @default(cuid())
  organizationId   String
  athleticTeamId   String
  opponentName     String
  homeAway         HomeAway @default(HOME)
  startTime        DateTime
  endTime          DateTime
  venue            String?
  calendarEventId  String?  // Linked CalendarEvent
  homeScore        Int?
  awayScore        Int?
  isFinal          Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  organization  Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  athleticTeam  AthleticTeam  @relation(fields: [athleticTeamId], references: [id], onDelete: Cascade)
  bracketEntry  TournamentBracket? @relation("BracketGame")
  playerStats   PlayerGameStat[]

  @@index([organizationId])
  @@index([athleticTeamId])
  @@index([organizationId, startTime])
  @@index([athleticTeamId, startTime])
}

model Practice {
  id               String   @id @default(cuid())
  organizationId   String
  athleticTeamId   String
  startTime        DateTime
  endTime          DateTime
  location         String?
  notes            String?
  calendarEventId  String?  // Linked CalendarEvent
  rrule            String?  // RFC 5545 recurrence
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  organization  Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  athleticTeam  AthleticTeam @relation(fields: [athleticTeamId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([athleticTeamId])
  @@index([athleticTeamId, startTime])
}

model Tournament {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  sportId        String
  startDate      DateTime
  endDate        DateTime
  format         TournamentFormat @default(SINGLE_ELIMINATION)
  calendarId     String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  sport        Sport               @relation(fields: [sportId], references: [id], onDelete: Cascade)
  brackets     TournamentBracket[]

  @@index([organizationId])
  @@index([sportId])
}

model TournamentBracket {
  id           String  @id @default(cuid())
  tournamentId String
  round        Int
  matchNumber  Int
  team1Id      String?
  team2Id      String?
  winnerId     String?
  gameId       String? @unique

  tournament Tournament    @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  team1      AthleticTeam? @relation("BracketTeam1", fields: [team1Id], references: [id], onDelete: SetNull)
  team2      AthleticTeam? @relation("BracketTeam2", fields: [team2Id], references: [id], onDelete: SetNull)
  winner     AthleticTeam? @relation("BracketWinner", fields: [winnerId], references: [id], onDelete: SetNull)
  game       Game?         @relation("BracketGame", fields: [gameId], references: [id], onDelete: SetNull)

  @@index([tournamentId, round])
}

model AthleticRoster {
  id             String   @id @default(cuid())
  organizationId String
  athleticTeamId String
  firstName      String
  lastName       String
  jerseyNumber   String?
  position       String?
  grade          String?
  height         String?
  weight         String?
  userId         String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  athleticTeam AthleticTeam @relation(fields: [athleticTeamId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  gameStats    PlayerGameStat[]

  @@unique([athleticTeamId, jerseyNumber])
  @@index([organizationId])
  @@index([athleticTeamId])
  @@index([userId])
}

model PlayerGameStat {
  id             String   @id @default(cuid())
  organizationId String
  rosterId       String
  gameId         String
  statKey        String
  statValue      Float
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  roster       AthleticRoster @relation(fields: [rosterId], references: [id], onDelete: Cascade)
  game         Game           @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@unique([rosterId, gameId, statKey])
  @@index([organizationId])
  @@index([rosterId])
  @@index([gameId])
}

model SportStatConfig {
  id             String   @id @default(cuid())
  organizationId String
  sportId        String
  statKey        String
  label          String
  sortOrder      Int      @default(0)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  sport        Sport        @relation(fields: [sportId], references: [id], onDelete: Cascade)

  @@unique([sportId, statKey])
  @@index([organizationId])
  @@index([sportId])
}

enum SportSeasonType {
  FALL
  WINTER
  SPRING
  YEAR_ROUND
}

enum TeamLevel {
  VARSITY
  VARSITY_B
  JUNIOR_VARSITY
  FRESHMAN
  FROSH_SOPH
  C_TEAM
  CLUB
  INTRAMURAL
  UNIFIED
}

enum HomeAway {
  HOME
  AWAY
  NEUTRAL
}

enum TournamentFormat {
  SINGLE_ELIMINATION
  DOUBLE_ELIMINATION
  ROUND_ROBIN
  POOL_PLAY
}

// ═══════════════════════════════════════════════════════════════════════
// MAINTENANCE MODULE
// ═══════════════════════════════════════════════════════════════════════

enum MaintenanceTicketStatus {
  BACKLOG
  TODO
  IN_PROGRESS
  ON_HOLD
  SCHEDULED
  QA
  DONE
  CANCELLED
}

enum MaintenanceCategory {
  ELECTRICAL
  PLUMBING
  HVAC
  STRUCTURAL
  CUSTODIAL_BIOHAZARD
  IT_AV
  GROUNDS
  OTHER
}

enum MaintenanceSpecialty {
  ELECTRICAL
  PLUMBING
  HVAC
  STRUCTURAL
  CUSTODIAL_BIOHAZARD
  IT_AV
  GROUNDS
  OTHER
}

enum MaintenancePriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum HoldReason {
  PARTS
  VENDOR
  ACCESS
  OTHER
}

enum MaintenanceActivityType {
  STATUS_CHANGE
  COMMENT
  ASSIGNMENT
  REASSIGNMENT
  INTERNAL_NOTE
  PHOTO_ADDED
}

model MaintenanceTicket {
  id                      String                  @id @default(cuid())
  organizationId          String
  ticketNumber            String
  title                   String
  description             String?
  status                  MaintenanceTicketStatus @default(BACKLOG)
  category                MaintenanceCategory
  specialty               MaintenanceSpecialty
  priority                MaintenancePriority     @default(MEDIUM)
  holdReason              HoldReason?
  holdNote                String?
  completionNote          String?
  cancellationReason      String?
  scheduledDate           DateTime?
  availabilityNote        String?
  photos                  String[]                @default([])
  completionPhotos        String[]                @default([])
  aiAnalysis              Json?
  version                 Int                     @default(1)
  estimatedRepairCostUSD  Float?
  staleAlertSent          Boolean                 @default(false)
  // PM-generated ticket fields
  pmScheduleId            String?                 // FK to PmSchedule that generated this ticket
  pmScheduledDueDate      DateTime?               // The scheduled due date for PM completion
  pmChecklistItems        String[]                @default([])  // Checklist item labels from the PM schedule
  pmChecklistDone         Boolean[]               @default([])  // Parallel array: true = item checked off
  assetId                 String?                               // Optional link to a MaintenanceAsset
  submittedById           String
  assignedToId            String?
  buildingId              String?
  areaId                  String?
  roomId                  String?
  schoolId                String?
  createdAt               DateTime                @default(now())
  updatedAt               DateTime                @updatedAt
  deletedAt               DateTime?

  organization  Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  submittedBy   User                      @relation("SubmittedBy", fields: [submittedById], references: [id], onDelete: Restrict)
  assignedTo    User?                     @relation("AssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)
  building      Building?                 @relation(fields: [buildingId], references: [id], onDelete: SetNull)
  area          Area?                     @relation(fields: [areaId], references: [id], onDelete: SetNull)
  room          Room?                     @relation(fields: [roomId], references: [id], onDelete: SetNull)
  school        School?                   @relation(fields: [schoolId], references: [id], onDelete: SetNull)
  asset         MaintenanceAsset?         @relation(fields: [assetId], references: [id], onDelete: SetNull)
  activities    MaintenanceTicketActivity[]
  laborEntries  MaintenanceLaborEntry[]
  costEntries   MaintenanceCostEntry[]
  complianceRecord ComplianceRecord?      @relation("ComplianceTicket")
  complianceRemediationRecord ComplianceRecord? @relation("RemediationTicket")

  @@unique([organizationId, ticketNumber])
  @@unique([pmScheduleId, pmScheduledDueDate])  // Idempotency: one ticket per PM schedule per due date
  @@index([organizationId, status])
  @@index([organizationId, assignedToId])
  @@index([organizationId, submittedById])
  @@index([organizationId, category])
  @@index([organizationId, schoolId])
  @@index([organizationId, deletedAt])
  @@index([pmScheduleId])
  @@index([assetId])
  // Dashboard/analytics composite indexes
  @@index([organizationId, deletedAt, status])
  @@index([organizationId, deletedAt, status, assignedToId])
  @@index([organizationId, deletedAt, status, schoolId])
  @@index([organizationId, deletedAt, createdAt])
  @@index([organizationId, deletedAt, buildingId, areaId, roomId])
  @@index([organizationId, priority])
}

model MaintenanceCounter {
  id               String       @id @default(cuid())
  organizationId   String       @unique
  lastTicketNumber Int          @default(0)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model TechnicianProfile {
  id               String                 @id @default(cuid())
  organizationId   String
  userId           String                 @unique
  specialties      MaintenanceSpecialty[]
  maxActiveTickets Int                    @default(10)
  loadedHourlyRate Float?
  isActive         Boolean                @default(true)
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

model MaintenanceTicketActivity {
  id             String                  @id @default(cuid())
  organizationId String
  ticketId       String
  actorId        String
  type           MaintenanceActivityType
  fromStatus     MaintenanceTicketStatus?
  toStatus       MaintenanceTicketStatus?
  assignedToId   String?
  content        String?
  isInternal     Boolean                 @default(false)
  metadata       Json?
  createdAt      DateTime                @default(now())

  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  ticket       MaintenanceTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  actor        User              @relation("ActivityActor", fields: [actorId], references: [id], onDelete: Restrict)
  assignedTo   User?             @relation("ActivityAssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)

  @@index([ticketId, createdAt])
  @@index([organizationId])
}

model MaintenanceLaborEntry {
  id              String    @id @default(cuid())
  organizationId  String
  ticketId        String
  technicianId    String
  startTime       DateTime
  endTime         DateTime?
  durationMinutes Int?
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  ticket       MaintenanceTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  technician   User              @relation(fields: [technicianId], references: [id], onDelete: Restrict)

  @@index([ticketId])
  @@index([organizationId])
  @@index([organizationId, startTime])
  @@index([organizationId, technicianId])
  @@index([technicianId, startTime])
}

model MaintenanceCostEntry {
  id             String    @id @default(cuid())
  organizationId String
  ticketId       String
  vendor         String?
  description    String
  amount         Float
  receiptUrl     String?
  createdById    String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  ticket       MaintenanceTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  createdBy    User              @relation(fields: [createdById], references: [id], onDelete: Restrict)

  @@index([ticketId])
  @@index([organizationId])
  @@index([organizationId, createdAt])
}

model MaintenanceAsset {
  id                    String    @id @default(cuid())
  organizationId        String
  assetNumber           String
  name                  String
  category              String?
  make                  String?
  model                 String?
  serialNumber          String?
  purchaseDate          DateTime?
  warrantyExpiry        DateTime?
  replacementCost       Float?
  expectedLifespanYears Int?
  repairThresholdPct    Float     @default(0.5)
  photos                String[]  @default([])
  notes                 String?
  status                String    @default("ACTIVE")
  buildingId            String?
  areaId                String?
  roomId                String?
  schoolId              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  deletedAt             DateTime?

  // Repeat repair intelligence fields
  aiRecommendation      Json?     // Stores replace-vs-repair AI output
  aiRecommendationAt    DateTime? // When recommendation was generated
  repeatAlertSentAt     DateTime? // Idempotency: last time repeat-repair alert was sent
  costAlertSentAt       DateTime? // Idempotency: last time cost-threshold alert was sent
  eolAlertSentAt        DateTime? // Idempotency: last time end-of-life alert was sent

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  building     Building?    @relation(fields: [buildingId], references: [id], onDelete: SetNull)
  area         Area?        @relation(fields: [areaId], references: [id], onDelete: SetNull)
  room         Room?        @relation(fields: [roomId], references: [id], onDelete: SetNull)
  school       School?      @relation(fields: [schoolId], references: [id], onDelete: SetNull)
  pmSchedules       PmSchedule[]
  tickets           MaintenanceTicket[]
  knowledgeArticles KnowledgeArticle[]

