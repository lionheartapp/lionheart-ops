  completedAt    DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  deletedAt      DateTime?

  organization   Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  school         School?             @relation(fields: [schoolId], references: [id], onDelete: SetNull)
  items          ITDeploymentBatchItem[]

  @@index([organizationId, status])
  @@index([organizationId, batchType])
  @@index([organizationId, deletedAt])
}

model ITDeploymentBatchItem {
  id             String            @id @default(cuid())
  organizationId String
  batchId        String
  deviceId       String
  studentId      String?
  processed      Boolean           @default(false)
  processedAt    DateTime?
  processedById  String?
  condition      ITDeviceCondition?
  damageNotes    String?
  damagePhotos   String[]          @default([])
  damageFee      Float?
  // AUP acknowledgment
  aupAcknowledged   Boolean        @default(false)
  aupAcknowledgedAt DateTime?
  aupSignature      String?        // Optional digital signature data
  // Fee tracking (for damage fee collection reporting)
  feeStatus        String?        @default("PENDING")  // PENDING | PAID | WAIVED
  feePaidAt        DateTime?
  feePaidAmount    Float?
  feeInvoiceNumber String?
  createdAt      DateTime          @default(now())

  batch          ITDeploymentBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  device         ITDevice          @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  student        Student?          @relation("DeploymentItemStudent", fields: [studentId], references: [id], onDelete: SetNull)

  @@unique([batchId, deviceId])
  @@index([organizationId, batchId])
  @@index([batchId, processed])
}

model ITSummerBatch {
  id             String            @id @default(cuid())
  organizationId String
  name           String
  batchType      ITSummerBatchType
  status         ITBatchStatus     @default(DRAFT)
  notes          String?
  createdById    String?
  startedAt      DateTime?
  completedAt    DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  deletedAt      DateTime?

  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  items          ITSummerBatchItem[]

  @@index([organizationId, status])
  @@index([organizationId, batchType])
  @@index([organizationId, deletedAt])
}

model ITSummerBatchItem {
  id             String          @id @default(cuid())
  organizationId String
  batchId        String
  deviceId       String
  completed      Boolean         @default(false)
  completedAt    DateTime?
  completedById  String?
  notes          String?
  createdAt      DateTime        @default(now())

  batch          ITSummerBatch   @relation(fields: [batchId], references: [id], onDelete: Cascade)
  device         ITDevice        @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@unique([batchId, deviceId])
  @@index([organizationId, batchId])
  @@index([batchId, completed])
}

model ITVendorRepairLog {
  id             String        @id @default(cuid())
  organizationId String
  repairId       String        @unique
  vendorName     String
  sentDate       DateTime?
  receivedDate   DateTime?
  estimatedCost  Float?
  actualCost     Float?
  invoiceNumber  String?
  receiptUrl     String?
  notes          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  repair         ITDeviceRepair @relation(fields: [repairId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

model ITStudentPasswordToken {
  id             String   @id @default(cuid())
  organizationId String
  studentId      String
  tokenHash      String   @unique
  expiresAt      DateTime
  usedAt         DateTime?
  createdAt      DateTime @default(now())

  student        Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([studentId])
  @@index([expiresAt])
}

// ─── Account Provisioning Models ──────────────────────────────────────────────

model ITProvisioningEvent {
  id             String                   @id @default(cuid())
  organizationId String
  eventType      ITProvisioningEventType
  status         ITProvisioningStatus     @default(PENDING)
  studentId      String?
  userId         String?                  // For staff onboarding events
  fromSchoolId   String?                  // Transfer source
  toSchoolId     String?                  // Transfer destination
  details        Json?                    // Extra context (ticket ID, account info, etc.)
  errorMessage   String?
  processedAt    DateTime?
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, eventType])
  @@index([organizationId, status])
  @@index([organizationId, createdAt])
}

model ITProvisioningConfig {
  id                    String   @id @default(cuid())
  organizationId        String   @unique
  autoEnrollEnabled     Boolean  @default(false)   // Auto-provision on new enrollment
  autoSuspendEnabled    Boolean  @default(false)   // Auto-suspend on transfer out
  orphanDetectionEnabled Boolean @default(false)   // Weekly orphan scan
  graduationArchiveEnabled Boolean @default(false) // Batch archive on graduation
  staffOnboardingEnabled Boolean @default(false)   // Auto-create setup ticket for new staff
  defaultOuPath         String?                    // Default Google OU for new students
  suspendedOuPath       String?                    // OU for suspended accounts
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model ITOrphanedAccount {
  id             String    @id @default(cuid())
  organizationId String
  email          String                             // The orphaned email
  accountType    String    @default("student")      // "student" | "staff"
  source         String    @default("google")       // "google" | "m365"
  detectedAt     DateTime  @default(now())
  resolvedAt     DateTime?
  resolution     String?                            // "kept" | "suspended" | "deleted"
  resolvedById   String?
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, resolvedAt])
  @@index([organizationId, email])
}

// ─── E-Rate Compliance ────────────────────────────────────────────────────────

model ITERateTask {
  id                    String          @id @default(cuid())
  organizationId        String
  taskType              ITERateTaskType
  title                 String
  description           String?
  dueDate               DateTime
  completedAt           DateTime?
  completedById         String?
  documentUrls          String[]        @default([])
  documentRetentionUntil DateTime?
  notes                 String?
  schoolYear            String          // e.g. "2025-2026"
  remindedAt60Days      Boolean         @default(false)
  remindedAt30Days      Boolean         @default(false)
  remindedAt14Days      Boolean         @default(false)
  remindedAt7Days       Boolean         @default(false)
  remindedAt3Days       Boolean         @default(false)
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  deletedAt             DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  completedBy  User?        @relation("ERateTaskCompletedBy", fields: [completedById], references: [id], onDelete: SetNull)
  documents    ITERateDocument[]

  @@unique([organizationId, taskType, schoolYear])
  @@index([organizationId, schoolYear])
  @@index([organizationId, dueDate])
  @@index([organizationId, deletedAt])
}

model ITERateDocument {
  id             String    @id @default(cuid())
  organizationId String
  taskId         String?
  title          String
  fileUrl        String
  fileType       String?
  retentionUntil DateTime
  uploadedById   String?
  schoolYear     String
  tags           String[]  @default([])
  createdAt      DateTime  @default(now())

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  task         ITERateTask?   @relation(fields: [taskId], references: [id], onDelete: SetNull)
  uploadedBy   User?          @relation("ERateDocUploadedBy", fields: [uploadedById], references: [id], onDelete: SetNull)

  @@index([organizationId, schoolYear])
  @@index([organizationId, retentionUntil])
  @@index([taskId])
}

// ─── Content Filter Integration ───────────────────────────────────────────────

model ITContentFilterConfig {
  id             String                @id @default(cuid())
  organizationId String
  provider       ITContentFilterProvider
  isEnabled      Boolean               @default(false)
  webhookSecret  String?
  apiKey         String?
  settings       Json?
  lastSyncAt     DateTime?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, provider])
}

model ITContentFilterEvent {
  id               String               @id @default(cuid())
  organizationId   String
  platform         ITContentFilterProvider
  eventType        ITFilterEventType
  externalEventId  String?
  studentName      String?
  studentEmail     String?
  url              String?
  category         String?
  teacherName      String?
  teacherEmail     String?
  actorId          String?              // User who took disposition action
  disposition      ITFilterDisposition  @default(PENDING)
  dispositionAt    DateTime?
  dispositionNotes String?
  ticketId         String?              // Linked IT ticket (auto-created for unblock requests)
  isAdminOnly      Boolean              @default(false)
  metadata         Json?
  createdAt        DateTime             @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  actor        User?        @relation("FilterEventActor", fields: [actorId], references: [id], onDelete: SetNull)
  ticket       ITTicket?    @relation(fields: [ticketId], references: [id], onDelete: SetNull)

  @@index([organizationId, platform])
  @@index([organizationId, eventType])
  @@index([organizationId, createdAt])
  @@index([organizationId, disposition])
  @@index([organizationId, isAdminOnly])
  @@index([externalEventId])
}

// ─── Security Incident Models ─────────────────────────────────────────────────

model SecurityIncident {
  id                    String                @id @default(cuid())
  incidentNumber        String                @unique
  organizationId        String
  schoolId              String?
  type                  SecurityIncidentType
  severity              IncidentSeverity
  status                IncidentStatus        @default(OPEN)
  title                 String
  description           String
  affectedSystems       String[]              @default([])
  affectedDeviceIds     String[]              @default([])
  affectedUserIds       String[]              @default([])
  piiInvolved           Boolean               @default(false)
  reportedById          String
  responderIds          String[]              @default([])
  evidenceFiles         Json[]                @default([])
  externalNotifications Json[]                @default([])
  resolutionSummary     String?
  lessonsLearned        String?
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  closedAt              DateTime?
  retainUntil           DateTime

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  school       School?      @relation(fields: [schoolId], references: [id], onDelete: SetNull)
  reportedBy   User         @relation("IncidentReportedBy", fields: [reportedById], references: [id], onDelete: Cascade)
  activities   SecurityIncidentActivity[]

  @@index([organizationId, status])
  @@index([organizationId, severity])
  @@index([organizationId, createdAt])
}

model SecurityIncidentCounter {
  id                  String       @id @default(cuid())
  organizationId      String       @unique
  lastIncidentNumber  Int          @default(0)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model SecurityIncidentActivity {
  id             String               @id @default(cuid())
  organizationId String
  incidentId     String
  actorId        String?
  type           IncidentActivityType
  fromStatus     String?
  toStatus       String?
  fromSeverity   String?
  toSeverity     String?
  content        String?
  metadata       Json?
  createdAt      DateTime             @default(now())

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  incident     SecurityIncident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  actor        User?            @relation("IncidentActivityActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([incidentId, createdAt])
  @@index([organizationId])
}

model NotificationPreference {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  type           String   // NotificationType string (e.g. "event_updated")
  emailEnabled   Boolean  @default(true)
  inAppEnabled   Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
  @@index([userId])
  @@index([organizationId])
}

// ─── Leo Memory Module ─────────────────────────────────────────────────────────

model Conversation {
  id             String    @id @default(cuid())
  organizationId String
  userId         String
  title          String?
  metadata       Json?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  organization Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages     ConversationMessage[]
  summaries    ConversationSummary[]
  memoryFacts  UserMemoryFact[]

  @@index([organizationId, userId, updatedAt])
  @@index([organizationId, deletedAt])
}

model ConversationMessage {
  id             String    @id @default(cuid())
  organizationId String
  conversationId String
  role           String    // "user" | "assistant" | "tool_call" | "tool_result"
  content        String
  tokenCount     Int?
  feedbackScore  Int?      // 1 = thumbs down, 5 = thumbs up
  toolName       String?
  toolSuccess    Boolean?
  embedding      Unsupported("vector(768)")?
  createdAt      DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([organizationId])
}

model ConversationSummary {
  id             String   @id @default(cuid())
  conversationId String
  summaryText    String
  messageCount   Int
  tokenCount     Int?
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
}

model UserAssistantProfile {
  id                 String   @id @default(cuid())
  userId             String   @unique
  responseLength     String?  // "short" | "medium" | "detailed"
  tonePreference     String?  // "casual" | "professional" | "mixed"
  frequentTopics     String[] @default([])
  commonActions      String[] @default([])
  domainExpertise    String[] @default([])
  communicationStyle Json?
  conversationCount  Int      @default(0)
  totalMessages      Int      @default(0)
  lastUpdated        DateTime @default(now())
  createdAt          DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model UserMemoryFact {
  id                   String    @id @default(cuid())
  userId               String
  factText             String
  category             String?   // "preference" | "pattern" | "context" | "instruction"
  importance           Float     @default(0.5)
  sourceConversationId String?
  embedding            Unsupported("vector(768)")?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  user               User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourceConversation Conversation? @relation(fields: [sourceConversationId], references: [id], onDelete: SetNull)

  @@index([userId, category])
  @@index([userId, importance])
}
