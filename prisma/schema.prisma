model ITTicket {
  id                 String          @id @default(cuid())
  organizationId     String
  ticketNumber       String          // IT-XXXX
  title              String
  description        String?
  status             ITTicketStatus  @default(BACKLOG)
  issueType          ITIssueType
  passwordSubType    ITPasswordSubType?
  avSubType          ITAVSubType?
  priority           ITPriority      @default(MEDIUM)
  holdReason         ITHoldReason?
  holdNote           String?
  resolutionNote     String?
  cancellationReason String?
  photos             String[]        @default([])
  source             ITTicketSource  @default(AUTHENTICATED)
  // Magic link submission metadata
  subRoomText        String?         // Room text from sub submission
  subDate            DateTime?       // Date of sub submission
  // Location hierarchy
  buildingId         String?
  areaId             String?
  roomId             String?
  schoolId           String?
  // People
  submittedById      String?         // Nullable for magic link / sub submissions
  assignedToId       String?
  // Device link (MDM)
  deviceId           String?         // Linked IT device (optional)
  // Public status check
  statusToken        String?         @unique // SHA-256 hash for public ticket status check
  lastStaleNotifiedAt DateTime?      // Track stale ticket notification timing
  // Content filter link
  filterPlatform     String?         // Which content filter created this ticket
  filterEventId      String?         // Reference to ITContentFilterEvent
  filterDisposition  String?         // PENDING/APPROVED/DENIED
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  deletedAt          DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  submittedBy  User?        @relation("ITTicketSubmittedBy", fields: [submittedById], references: [id], onDelete: SetNull)
  assignedTo   User?        @relation("ITTicketAssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)
  building     Building?    @relation(fields: [buildingId], references: [id], onDelete: SetNull)
  area         Area?        @relation(fields: [areaId], references: [id], onDelete: SetNull)
  room         Room?        @relation(fields: [roomId], references: [id], onDelete: SetNull)
  school       School?      @relation(fields: [schoolId], references: [id], onDelete: SetNull)
  device       ITDevice?    @relation(fields: [deviceId], references: [id], onDelete: SetNull)
  activities   ITTicketActivity[]
  filterEvents ITContentFilterEvent[]

  @@unique([organizationId, ticketNumber])
  @@index([organizationId, status])
  @@index([organizationId, assignedToId])
  @@index([organizationId, submittedById])
  @@index([organizationId, issueType])
  @@index([organizationId, schoolId])
  @@index([organizationId, deletedAt])
  @@index([organizationId, deletedAt, status])
  @@index([organizationId, deletedAt, status, assignedToId])
  @@index([organizationId, deletedAt, status, schoolId])
  @@index([organizationId, deletedAt, createdAt])
  @@index([organizationId, priority])
}

